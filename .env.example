# Supabase — get these from your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# WhatsApp Notifications (Phase 1 — Twilio)
# Set to 'true' to enable WhatsApp notifications on purchase invoice creation
VITE_ENABLE_WHATSAPP=false

# Supabase Edge Function Environment Variables (set in Supabase Dashboard → Edge Functions → Secrets)
# ENABLE_WHATSAPP_NOTIFICATIONS=false
# TWILIO_ACCOUNT_SID=xxxx
# TWILIO_AUTH_TOKEN=xxxx
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
